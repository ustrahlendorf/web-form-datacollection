# Taskfile inputs (non-secret)
#
# This file is loaded automatically by the repo root Taskfile.yml via `dotenv: ["taskfile.env"]`.
# Keep this file free of credentials/secrets. Use AWS SSO / credential_process / keychain-based auth instead.
#
# Optional CDK cost allocation tags (see infrastructure/app.py). After deploy, activate the same
# keys under AWS Billing > Cost allocation tags for Cost Explorer.
# COST_CENTER=engineering
# APPLICATION=web-form-verbrauch
# OWNER=team@example.com
#
# Required for CDK operations (defaults to eu-central-1 if unset in Taskfile vars)
AWS_REGION=eu-central-1

# DataLake S3 bucket (CDK DataLakeStack output; used by export-datalake and manual exports)
DATALAKE_BUCKET_NAME=data-collection-datalake-dev-009173211474-eu-central-1

# Arn for Secrets Manager (required for Scheduler, SchedulerFrequent stacks)
VIESSMANN_CREDENTIALS_SECRET_ARN=arn:aws:secretsmanager:eu-central-1:009173211474:secret:heating/viessmann/credentials-9UNcoc

# Required for DynamoDBStack naming (CDK synth/deploy tasks that touch DynamoDB/API/Frontend)
# Example:
# ACTIVE_SUBMISSIONS_TABLE_NAME=submissions-2025
# PASSIVE_SUBMISSIONS_TABLE_NAME=submissions-2026
ACTIVE_SUBMISSIONS_TABLE_NAME=submissions-2026
PASSIVE_SUBMISSIONS_TABLE_NAME=submissions-2025

# SSM namespace prefix for HeatingDataCollection contract
# (single environment => no env segment by design)
SSM_NAMESPACE_PREFIX=/HeatingDataCollection

# InitStack "static/future" defaults (documented here for operators)
# Note: current CDK InitStack sets these values in code; this file is the operator-facing source of truth.
INIT_SCHEMA_VERSION=1
INIT_ENABLE_PASSIVE_READS=false
INIT_ROLLOVER_RUNBOOK_VERSION=2026-01


